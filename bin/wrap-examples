#!/usr/bin/env bash
#
# Wraps .html.ruby example files in a Wrapper(style: "contain: layout style;") { }
#
# Usage:
#   bin/wrap-examples                           # wraps all files in app/views/examples/examples/
#   bin/wrap-examples path/to/file.html.ruby    # wraps a single file
#   bin/wrap-examples file1.html.ruby file2.html.ruby  # wraps specific files

set -euo pipefail

wrap_file() {
  local f="$1"

  # Check if already wrapped
  if head -1 "$f" | grep -q '^Wrapper'; then
    echo "SKIP (already wrapped): $(basename "$f")"
    return
  fi

  # Indent every line by 2 spaces
  sed -i 's/^/  /' "$f"

  # Insert Wrapper at top
  sed -i '1i\Wrapper(style: "contain: layout style;") {' "$f"

  # Append closing brace
  echo '}' >> "$f"

  echo "DONE: $(basename "$f")"
}

if [ $# -gt 0 ]; then
  for f in "$@"; do
    wrap_file "$f"
  done
else
  for f in app/views/examples/examples/*.html.ruby; do
    wrap_file "$f"
  done
fi
